$normalizePath = static function(string $path): string {
    $parsedPath = parse_url($path, PHP_URL_PATH);
    if (is_string($parsedPath) && $parsedPath !== "") {
        $path = $parsedPath;
    }
    if ($path === "") {
        return "/";
    }
    if (!str_starts_with($path, "/")) {
        $path = "/{$path}";
    }
    if ($path !== "/") {
        $path = rtrim($path, "/");
    }
    return $path;
};
$lookfor = $normalizePath((string) ($_SERVER["SCRIPT_URL"] ?? "/"));
$homeLinks = [
    [
        "title" => "Iowa Atmospheric Observatory",
