        "url" => "https://weather.im"
    ],
];
$isActiveNavItem = static function(string $currentPath, array $sub)
    use ($normalizePath): bool {
    if (!array_key_exists("url", $sub)) {
        return FALSE;
    }
    $targetPath = $normalizePath((string) $sub["url"]);
    if ($currentPath === $targetPath) {
        return TRUE;
    }
    if ($targetPath !== "/" &&
        str_starts_with($currentPath, "{$targetPath}/")) {
        return TRUE;
    }
    return FALSE;
};
$renderDropdownItems = static function(array $dropdownItems, string $currentPath,
    callable $isActiveNavItem): string {
    $items = "";
    foreach ($dropdownItems as $sub) {
        $type = $sub["type"] ?? "link";
        if ($type === "divider") {
            $items .= "<li><hr class=\"dropdown-divider\"></li>\n";
            continue;
        }
        if ($type === "header") {
            $items .= sprintf(
                "<li><h6 class=\"dropdown-header\">%s</h6></li>\n",
                htmlspecialchars($sub["title"] ?? "", ENT_QUOTES)
            );
            continue;
        }
        $isActive = $isActiveNavItem($currentPath, $sub);
        $items .= sprintf(
            "<li><a class=\"dropdown-item%s\" href=\"%s\">%s</a></li>\n",
            $isActive ? " active" : "",
            htmlspecialchars($sub["url"], ENT_QUOTES),
            htmlspecialchars($sub["title"], ENT_QUOTES)
        );
    }
    return $items;
};
