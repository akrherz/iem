<?php
require_once "../../../config/settings.inc.php";
define("IEM_APPID", 170);
require_once "../../../include/mlib.php";
require_once "../../../include/forms.php";
force_https();
require_once "../../../include/myview.php";
require_once "../../../include/iemprop.php";
$t = new MyView();

$wfo = get_str404("wfo", "DMX");
$thisyear = date("Y");
$sdate = get_str404("sdate", "{$thisyear}-01-01");
$edate = get_str404("edate", "{$thisyear}-12-31");
$otype = get_str404("otype", "1.C.13");
$threshold = get_str404("threshold", "SLGT");
$oparts = explode(".", $otype);
$phsig = $_GET["phsig"] ?? [];

$wsurl = sprintf("http://iem.local/json/outlook_and_vtec.py?%s", http_build_query([
    "wfo" => $wfo,
    "day" => $oparts[0],
    "threshold" => $threshold,
    "outlook_type" => $oparts[1],
    "cycle" => $oparts[2],
    "sdate" => $sdate,
    "edate" => $edate,
    "phsig" => implode(",", $phsig),
]));
$jobj = file_get_contents($wsurl);
$jobj = json_decode($jobj, true);

/**
 * Simple helper to escape output for HTML contexts.  We use this for all
 * dynamic output in this page to prevent XSS issues.  We also cast to string
 * to prevent issues with non-string values.
 * @param mixed $value The value to escape for HTML output
 * @return string The escaped string safe for HTML contexts
 */
function h($value) {
    return htmlspecialchars((string) $value, ENT_QUOTES | ENT_SUBSTITUTE, "UTF-8");
}

$table = "";
$rows = [];
foreach ($jobj["outlooks"] as $o) {
    $safeDate = h($o["date"]);
    $safeIssue = h($o["utc_issue"]);
    $safeExpire = h($o["utc_expire"]);
    $safeOutlook = h("{$o["day"]} {$o["threshold"]} {$o["outlook_type"]}@{$o["cycle"]}");
    $eventCount = count($o["events"]);
    $eventsHtml = "";
    $eventsText = [];

    $table .= <<<EOM
<tr><td>{$safeDate}</td>
<td>{$safeIssue}</td><td>{$safeExpire}</td>
<td>{$safeOutlook}</td>
<td>{$o["overlap_percent"]}</td>
<td data-event-count="{$eventCount}">
EOM;
    foreach ($o["events"] as $e) {
        $uri = h($e["vtec_app_uri"]);
        $label = h($e["label"]);
        $eventsHtml .= sprintf('<a href="%s" target="_new">%s</a><br />', $uri, $label);
        $eventsText[] = $e["label"];
    }
    $table .= $eventsHtml ?: "<span class='text-muted'>None</span>";
    $table .= "</td></tr>";
    $rows[] = [
        "date" => $o["date"],
        "utc_issue" => $o["utc_issue"],
        "utc_expire" => $o["utc_expire"],
        "outlook" => "{$o["day"]} {$o["threshold"]} {$o["outlook_type"]}@{$o["cycle"]}",
        "event_count" => $eventCount,
        "events_html" => $eventsHtml,
        "overlap_percent" => $o["overlap_percent"],
        "events_text" => implode(" | ", $eventsText),
    ];
}

$t->jsextra = <<<EOM
<script src="https://unpkg.com/tabulator-tables@6.2.1/dist/js/tabulator.min.js"></script>
<script src="index.module.js?v=2" type="module"></script>
EOM;
$t->headextra = <<<EOM
<link rel="stylesheet" href="https://unpkg.com/tabulator-tables@6.2.1/dist/css/tabulator.min.css" />
<link rel="stylesheet" type="text/css" href="index.css" />
EOM;
$t->title = "SPC/WPC Outlooks with Warnings by WFO";

$wfoSelect = networkSelect("WFO", $wfo, [], $selectName="wfo");

$opts = [
    "1.C.1" => "Day 1 Convective @1z",
    "1.C.20" => "Day 1 Convective @20z",
    "1.C.16" => "Day 1 Convective @16z",
    "1.C.13" => "Day 1 Convective @13z",
    "1.C.6" => "Day 1 Convective @6z",
